extends Area2D

class_name Enemy

var direction = 1
var start_position = 0
var walking_distance = 50
var last_turn = 0
var walk_length = 3000
@export var horizontal_speed = 35
@export var vertical_speed = 100

@onready var ray_cast_2d = $RayCast2D as RayCast2D
@onready var animated_sprite_2d = $AnimatedSprite2D as AnimatedSprite2D

func _ready():
	last_turn = Time.get_ticks_msec()

func _process(delta):
	position.x += direction * delta * horizontal_speed
	
	if !ray_cast_2d.is_colliding():
		position.y += delta * vertical_speed
	
	var current_time = Time.get_ticks_msec()
	if (current_time - last_turn > walk_length):
		last_turn = current_time
		direction *= -1

func die():
	horizontal_speed = 0
	vertical_speed = 0
	animated_sprite_2d.play("death")
	set_collision_layer_value(3,false)
	set_collision_mask_value(1, false)
